// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH (NextAuth v5 required tables) ─────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── USERS ───────────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String?   @unique
  emailVerified   DateTime?
  image           String?
  username        String?   @unique
  displayName     String?
  walletAddress   String?   @unique
  mode            Mode      @default(SOLO)
  level           Int       @default(1)
  totalXp         BigInt    @default(0)
  offChainTokens  BigInt    @default(0)
  onChainSynced   Boolean   @default(false)
  onboardingDone  Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  characters      Character[]
  workouts        Workout[]
  streak          Streak?
  ownedGyms       Gym[]           @relation("GymOwner")
  gymMemberships  GymMember[]
  gymCoOwnerships GymCoOwner[]
  rewards         Reward[]
  transactions    Transaction[]
  challenges      Challenge[]     @relation("ChallengeCreator")
  fitnessSyncs    FitnessSync[]
}

enum Mode {
  SOLO
  SOCIAL
}

// ─── CHARACTERS ───────────────────────────────────────────────────────────────

model Character {
  id                  String    @id @default(cuid())
  userId              String
  name                String
  bodyType            BodyType
  strength            Int       @default(10)
  stamina             Int       @default(10)
  discipline          Int       @default(10)
  metabolism          Int       @default(10)
  transformationStage Int       @default(0) // 0–5
  isActive            Boolean   @default(true)
  nftTokenId          String?
  createdAt           DateTime  @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workouts Workout[]
}

enum BodyType {
  SKINNY
  AVERAGE
  OVERWEIGHT
}

// ─── WORKOUT PLANS ────────────────────────────────────────────────────────────

model WorkoutPlan {
  id            String      @id @default(cuid())
  name          String
  type          PlanType
  description   String?
  targetStats   Json        @default("{}")
  durationWeeks Int         @default(4)
  isSystem      Boolean     @default(true)
  createdBy     String?

  workouts Workout[]
}

enum PlanType {
  STRENGTH
  FAT_LOSS
  HYBRID
  CALISTHENICS
}

// ─── WORKOUTS ─────────────────────────────────────────────────────────────────

model Workout {
  id           String        @id @default(cuid())
  userId       String
  characterId  String?
  planId       String?
  source       WorkoutSource @default(IN_GAME)
  externalId   String?
  durationMins Int
  intensity    Intensity     @default(MEDIUM)
  adherencePct Decimal       @default(100) @db.Decimal(5, 2)
  xpEarned     Int           @default(0)
  tokensEarned BigInt        @default(0)
  fitnessBoost Decimal       @default(0) @db.Decimal(5, 4)
  completedAt  DateTime      @default(now())
  createdAt    DateTime      @default(now())

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  character Character?  @relation(fields: [characterId], references: [id])
  plan      WorkoutPlan? @relation(fields: [planId], references: [id])
}

enum WorkoutSource {
  IN_GAME
  API_SYNC
}

enum Intensity {
  LOW
  MEDIUM
  HIGH
}

// ─── STREAKS ──────────────────────────────────────────────────────────────────

model Streak {
  id               String    @id @default(cuid())
  userId           String    @unique
  currentStreak    Int       @default(0)
  longestStreak    Int       @default(0)
  lastWorkoutAt    DateTime?
  streakFreezeCount Int      @default(0)
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── GYMS ─────────────────────────────────────────────────────────────────────

model Gym {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        GymType  @default(PLAYER)
  ownerId     String?
  reputation  Int      @default(0)
  memberCount Int      @default(0)
  maxMembers  Int      @default(50)
  monthlyFee  BigInt   @default(100)
  nftTokenId  String?
  onChain     Boolean  @default(false)
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner      User?        @relation("GymOwner", fields: [ownerId], references: [id])
  members    GymMember[]
  coOwners   GymCoOwner[]
  equipment  Equipment[]
  npcClients NpcClient[]
  challenges Challenge[]
}

enum GymType {
  SYSTEM
  PLAYER
}

// ─── GYM MEMBERS ─────────────────────────────────────────────────────────────

model GymMember {
  id       String     @id @default(cuid())
  gymId    String
  userId   String
  role     MemberRole @default(MEMBER)
  joinedAt DateTime   @default(now())

  gym  Gym  @relation(fields: [gymId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gymId, userId])
}

enum MemberRole {
  MEMBER
  TRAINER
  CO_OWNER
}

// ─── GYM CO-OWNERS ───────────────────────────────────────────────────────────

model GymCoOwner {
  id           String  @id @default(cuid())
  gymId        String
  userId       String
  revenueShare Decimal @db.Decimal(5, 2)
  onChainShare Boolean @default(false)

  gym  Gym  @relation(fields: [gymId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gymId, userId])
}

// ─── EQUIPMENT ───────────────────────────────────────────────────────────────

model Equipment {
  id           String   @id @default(cuid())
  gymId        String
  name         String
  type         String
  level        Int      @default(1)
  purchaseCost BigInt
  upgradeCost  BigInt?
  capacity     Int      @default(5)
  statBonus    Json     @default("{}")
  nftTokenId   String?
  purchasedAt  DateTime @default(now())

  gym Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)
}

// ─── NPC CLIENTS ─────────────────────────────────────────────────────────────

model NpcClient {
  id           String  @id @default(cuid())
  gymId        String
  name         String
  goal         String
  satisfaction Int     @default(50)
  spendingRate BigInt  @default(10)
  active       Boolean @default(true)

  gym Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)
}

// ─── REWARDS ─────────────────────────────────────────────────────────────────

model Reward {
  id          String     @id @default(cuid())
  userId      String
  type        RewardType
  baseAmount  BigInt
  bonusAmount BigInt     @default(0)
  fitnessBoost Decimal   @default(0) @db.Decimal(5, 4)
  totalAmount BigInt
  sourceId    String?
  claimed     Boolean    @default(false)
  onChainTx   String?
  createdAt   DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum RewardType {
  WORKOUT
  GYM_INCOME
  CHALLENGE
  STREAK_BONUS
  REFERRAL
}

// ─── TRANSACTIONS ─────────────────────────────────────────────────────────────

model Transaction {
  id            String          @id @default(cuid())
  userId        String
  type          TransactionType
  amount        BigInt
  balanceBefore BigInt
  balanceAfter  BigInt
  description   String?
  txHash        String?
  chainId       Int?
  createdAt     DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum TransactionType {
  EARN
  SPEND
  TRANSFER
  ON_CHAIN_CLAIM
  GYM_FEE
  EQUIPMENT_BUY
}

// ─── CHALLENGES ───────────────────────────────────────────────────────────────

model Challenge {
  id         String          @id @default(cuid())
  title      String
  type       ChallengeType
  creatorId  String
  gymId      String?
  prizePool  BigInt          @default(0)
  startAt    DateTime?
  endAt      DateTime?
  status     ChallengeStatus @default(PENDING)
  metadata   Json            @default("{}")
  createdAt  DateTime        @default(now())

  creator User @relation("ChallengeCreator", fields: [creatorId], references: [id])
  gym     Gym? @relation(fields: [gymId], references: [id])
}

enum ChallengeType {
  ONE_V_ONE
  GROUP
  GYM_VS_GYM
  COMMUNITY
}

enum ChallengeStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

// ─── FITNESS SYNC ─────────────────────────────────────────────────────────────

model FitnessSync {
  id           String    @id @default(cuid())
  userId       String
  syncDate     DateTime
  durationMins Int
  intensity    Intensity @default(MEDIUM)
  adherencePct Decimal   @db.Decimal(5, 2)
  streakCount  Int       @default(0)
  fitnessBoost Decimal   @default(0) @db.Decimal(5, 4)
  applied      Boolean   @default(false)
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, syncDate])
}
